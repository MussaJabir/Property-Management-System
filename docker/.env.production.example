# /opt/pms/.env — PMS production env on the demo box.
# Copy to /opt/pms/.env and fill in the real values. chmod 600.

# ---- App ----
APP_ENV=production
APP_DEBUG=false                          # MUST stay false in production (also enforced in-app)
APP_KEY=base64:CHANGE-ME-RUN-php-artisan-key-generate
PMS_TAG=latest   # the deploy workflow overrides this with the git SHA

# ---- Postgres ----
DB_DATABASE=pms
DB_USERNAME=pms
DB_PASSWORD=CHANGE-ME-strong-password

# ---- Redis (no password for demo; lock down in prod) ----
REDIS_PASSWORD=null

# ---- Backblaze B2 (file storage) ----
FILESYSTEM_DISK=b2
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_REGION=us-west-002
B2_BUCKET=pms-prod
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_BACKUP_BUCKET=pms-backups

# ---- Mail ----
# Option A — cPanel SMTP (recommended for now: uses the domain's own mail
# server, so SPF/DKIM are already in place → good inbox delivery).
MAIL_MAILER=smtp
MAIL_SCHEME=smtps                       # smtps = SSL on 465; use smtp for STARTTLS on 587
MAIL_HOST=mail.bjptechnologies.co.tz
MAIL_PORT=465
MAIL_USERNAME=no-reply@bjptechnologies.co.tz
MAIL_PASSWORD=                          # the cPanel mailbox password
MAIL_FROM_ADDRESS=no-reply@bjptechnologies.co.tz
MAIL_FROM_NAME="PMS — BJP Technologies"

# Option B — Resend (switch MAIL_MAILER=resend and fill the key; needs DNS
# verification in the Resend dashboard).
RESEND_KEY=

# ---- SMS (Beem Africa) ----
# When set, account-activation links are also sent by SMS (covers renters and
# staff without an email address). Leave blank to use email only.
BEEM_API_KEY=
BEEM_SECRET=
BEEM_SOURCE_ADDR=PMS
