# /opt/pms/.env — PMS production env on the demo box.
# Copy to /opt/pms/.env and fill in the real values. chmod 600.

# ---- App ----
APP_KEY=base64:CHANGE-ME-RUN-php-artisan-key-generate
PMS_TAG=latest   # the deploy workflow overrides this with the git SHA

# ---- Postgres ----
DB_DATABASE=pms
DB_USERNAME=pms
DB_PASSWORD=CHANGE-ME-strong-password

# ---- Redis (no password for demo; lock down in prod) ----
REDIS_PASSWORD=null

# ---- Backblaze B2 (file storage) ----
FILESYSTEM_DISK=b2
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_REGION=us-west-002
B2_BUCKET=pms-prod
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_BACKUP_BUCKET=pms-backups

# ---- Mail (Resend) ----
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=no-reply@bjptechnologies.co.tz
MAIL_FROM_NAME="PMS"
RESEND_KEY=
